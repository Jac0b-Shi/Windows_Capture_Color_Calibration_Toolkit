<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WgcColorCalibrator.App.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="16" Padding="32">
            <TextBlock x:Uid="DiagnosticsTitle" Style="{ThemeResource TitleTextBlockStyle}" />
            <Grid ColumnSpacing="16" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Uid="DiagnosticsAppVersionLabel" Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" />
                <TextBlock x:Name="AppVersionTextBlock" Grid.Row="0" Grid.Column="1" />
                <TextBlock x:Uid="DiagnosticsDotNetLabel" Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" />
                <TextBlock x:Name="DotNetTextBlock" Grid.Row="1" Grid.Column="1" />
                <TextBlock x:Uid="DiagnosticsWindowsLabel" Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" />
                <TextBlock x:Name="WindowsTextBlock" Grid.Row="2" Grid.Column="1" />
                <TextBlock x:Uid="DiagnosticsWindowsAppSdkLabel" Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" />
                <TextBlock x:Name="WindowsAppSdkTextBlock" Grid.Row="3" Grid.Column="1" />
                <TextBlock x:Uid="DiagnosticsWindowsAppRuntimeLabel" Grid.Row="4" Grid.Column="0" FontWeight="SemiBold" />
                <TextBlock x:Name="WindowsAppRuntimeTextBlock" Grid.Row="4" Grid.Column="1" />
                <TextBlock x:Uid="DiagnosticsWgcLabel" Grid.Row="5" Grid.Column="0" FontWeight="SemiBold" />
                <TextBlock x:Name="WgcTextBlock" Grid.Row="5" Grid.Column="1" />
                <TextBlock x:Uid="DiagnosticsHdrLabel" Grid.Row="6" Grid.Column="0" FontWeight="SemiBold" />
                <TextBlock x:Name="HdrTextBlock" Grid.Row="6" Grid.Column="1" />
                <TextBlock x:Uid="DiagnosticsPixelFormatLabel" Grid.Row="7" Grid.Column="0" FontWeight="SemiBold" />
                <TextBlock x:Name="PixelFormatTextBlock" Grid.Row="7" Grid.Column="1" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>

