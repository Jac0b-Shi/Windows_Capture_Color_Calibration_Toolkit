<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WgcColorCalibrator.App.Pages.ChartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <Grid Padding="32" RowSpacing="24" ColumnSpacing="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                x:Uid="ChartTitle"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Style="{ThemeResource TitleTextBlockStyle}" />

            <StackPanel
                Grid.Row="1"
                Grid.Column="0"
                Spacing="12">
                <TextBlock x:Uid="ChartTypeLabel" FontWeight="SemiBold" />
                <ComboBox x:Name="ChartTypeComboBox" MinWidth="240">
                    <ComboBoxItem x:Uid="ChartTypeManual" Tag="manual-single-color" />
                    <ComboBoxItem x:Uid="ChartTypeNearWhite" Tag="near-white" />
                    <ComboBoxItem x:Uid="ChartTypeGrayscale" Tag="grayscale" />
                </ComboBox>

                <StackPanel x:Name="SdrManualPanel" Spacing="8" Visibility="Collapsed">
                    <TextBlock x:Uid="ManualColorLabel" />
                    <TextBox x:Name="ManualColorHexTextBox" x:Uid="ManualColorHexTextBox" Text="#FFFFFF" LostFocus="ManualColorHexTextBox_LostFocus" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <NumberBox x:Name="ManualRedNumberBox" x:Uid="ManualRedNumberBox" Grid.Column="0" Minimum="0" Maximum="255" Value="255" />
                        <NumberBox x:Name="ManualGreenNumberBox" x:Uid="ManualGreenNumberBox" Grid.Column="1" Minimum="0" Maximum="255" Value="255" />
                        <NumberBox x:Name="ManualBlueNumberBox" x:Uid="ManualBlueNumberBox" Grid.Column="2" Minimum="0" Maximum="255" Value="255" />
                    </Grid>
                    <TextBlock x:Uid="ManualColorPreviewLabel" />
                    <Rectangle x:Name="ManualColorPreview" Width="64" Height="64" Fill="White" Stroke="{ThemeResource TextFillColorPrimaryBrush}" StrokeThickness="1" />
                    <TextBlock x:Name="ManualColorNormalizedTextBlock" Text="#FFFFFF" />
                </StackPanel>

                <StackPanel x:Name="HdrManualPanel" Spacing="8" Visibility="Collapsed">
                    <TextBlock x:Uid="ManualHdrColorLabel" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <NumberBox x:Name="ManualHdrRedNumberBox" x:Uid="ManualHdrRedNumberBox" Grid.Column="0" Minimum="0" Value="1.0" />
                        <NumberBox x:Name="ManualHdrGreenNumberBox" x:Uid="ManualHdrGreenNumberBox" Grid.Column="1" Minimum="0" Value="1.0" />
                        <NumberBox x:Name="ManualHdrBlueNumberBox" x:Uid="ManualHdrBlueNumberBox" Grid.Column="2" Minimum="0" Value="1.0" />
                    </Grid>
                    <TextBlock x:Name="ManualHdrColorNormalizedTextBlock" Text="R=1.0 G=1.0 B=1.0" />
                </StackPanel>

                <StackPanel x:Name="GrayscalePanel" Spacing="8" Visibility="Collapsed">
                    <TextBlock x:Uid="GrayscaleStepsLabel" />
                    <NumberBox x:Name="GrayscaleStepsNumberBox" x:Uid="GrayscaleStepsNumberBox" Minimum="2" Maximum="256" Value="5" />
                </StackPanel>
            </StackPanel>

            <StackPanel
                Grid.Row="1"
                Grid.Column="1"
                Spacing="12">
                <TextBlock x:Uid="ChartLayoutLabel" FontWeight="SemiBold" />
                <ComboBox x:Name="PatchSizePresetComboBox" x:Uid="PatchSizePresetComboBox" MinWidth="200">
                    <ComboBoxItem x:Uid="PatchSizePresetCompact" Tag="64" />
                    <ComboBoxItem x:Uid="PatchSizePresetStandard" Tag="128" />
                    <ComboBoxItem x:Uid="PatchSizePresetLarge" Tag="256" />
                </ComboBox>
                <Grid ColumnSpacing="8" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <NumberBox x:Name="PatchWidthNumberBox" x:Uid="PatchWidthNumberBox" Grid.Row="0" Grid.Column="0" Minimum="1" Maximum="4096" Value="64" />
                    <NumberBox x:Name="PatchHeightNumberBox" x:Uid="PatchHeightNumberBox" Grid.Row="0" Grid.Column="1" Minimum="1" Maximum="4096" Value="64" />
                    <NumberBox x:Name="GapNumberBox" x:Uid="GapNumberBox" Grid.Row="1" Grid.Column="0" Minimum="0" Maximum="1024" Value="8" />
                    <NumberBox x:Name="BorderNumberBox" x:Uid="BorderNumberBox" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="1024" Value="16" />
                    <NumberBox x:Name="SafeSampleInsetNumberBox" x:Uid="SafeSampleInsetNumberBox" Grid.Row="2" Grid.Column="0" Minimum="0" Maximum="1024" Value="8" />
                    <NumberBox x:Name="ColumnCountNumberBox" x:Uid="ColumnCountNumberBox" Grid.Row="2" Grid.Column="1" Minimum="1" Maximum="64" Value="4" />
                    <TextBox x:Name="BackgroundColorTextBox" x:Uid="BackgroundColorTextBox" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Text="#000000" />
                </Grid>
            </StackPanel>

            <StackPanel
                Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Spacing="12">
                <TextBlock x:Uid="ChartHdrLabel" FontWeight="SemiBold" />
            <Grid ColumnSpacing="8" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="OutputModeComboBox" x:Uid="OutputModeComboBox" Grid.Row="0" Grid.Column="0" MinWidth="160">
                    <ComboBoxItem x:Uid="OutputModeSdr" Tag="SdrSrgb" />
                    <ComboBoxItem x:Uid="OutputModeHdrScRgb" Tag="HdrScRgb" />
                    <ComboBoxItem x:Uid="OutputModeHdr10" Tag="Hdr10" />
                </ComboBox>
                <ComboBox x:Name="ToneMappingModeComboBox" x:Uid="ToneMappingModeComboBox" Grid.Row="0" Grid.Column="1" MinWidth="160">
                    <ComboBoxItem x:Uid="ToneMappingModeDirect" Tag="DirectScRgb" />
                    <ComboBoxItem x:Uid="ToneMappingModeReference" Tag="ReferenceWhiteScaled" />
                </ComboBox>
                <NumberBox x:Name="PaperWhiteNumberBox" x:Uid="PaperWhiteNumberBox" Grid.Row="0" Grid.Column="2" Minimum="1" Maximum="10000" Value="200" />
                <NumberBox x:Name="PeakBrightnessNumberBox" x:Uid="PeakBrightnessNumberBox" Grid.Row="0" Grid.Column="3" Minimum="1" Maximum="10000" Value="1000" />
                <NumberBox x:Name="ExposureNumberBox" x:Uid="ExposureNumberBox" Grid.Row="1" Grid.Column="0" Minimum="-10" Maximum="10" Value="0" SmallChange="0.1" />
                <TextBlock x:Name="HdrStatusTextBlock" x:Uid="HdrStatusTextBlock" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" TextWrapping="WrapWholeWords" />
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Uid="HdrBehaviorLabel" VerticalAlignment="Center" />
                    <ComboBox x:Name="HdrBehaviorComboBox" x:Uid="HdrBehaviorComboBox" MinWidth="180">
                        <ComboBoxItem x:Uid="HdrBehaviorCancel" Tag="Cancel" />
                        <ComboBoxItem x:Uid="HdrBehaviorSwitchToSdr" Tag="SwitchToSdr" />
                        <ComboBoxItem x:Uid="HdrBehaviorAllowClipping" Tag="AllowClippingExperiment" />
                    </ComboBox>
                </StackPanel>
            </Grid>
            </StackPanel>

            <StackPanel
                Grid.Row="3"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Orientation="Horizontal"
                Spacing="8">
                <Button x:Uid="GenerateButton" Click="GenerateButton_Click" />
                <Button x:Uid="OpenChartWindowButton" Click="OpenChartWindowButton_Click" />
                <Button x:Uid="CloseChartWindowButton" Click="CloseChartWindowButton_Click" />
                <Button x:Uid="ToggleDebugOverlayButton" Click="ToggleDebugOverlayButton_Click" />
                <Button x:Uid="ImportJsonButton" Click="ImportJsonButton_Click" />
                <Button x:Uid="ImportCsvButton" Click="ImportCsvButton_Click" />
                <Button x:Uid="ExportJsonButton" Click="ExportJsonButton_Click" />
                <Button x:Uid="ExportCsvButton" Click="ExportCsvButton_Click" />
            </StackPanel>

            <StackPanel
                Grid.Row="4"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Spacing="8">
                <TextBlock x:Uid="ChartSummaryLabel" FontWeight="SemiBold" />
                <TextBlock x:Name="SummaryTextBlock" TextWrapping="WrapWholeWords" />
                <InfoBar
                    x:Name="DirtyInfoBar"
                    x:Uid="DirtyInfoBar"
                    IsOpen="False"
                    Severity="Informational" />
            </StackPanel>

            <StackPanel
                Grid.Row="5"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Spacing="12">
                <TextBlock x:Uid="ChartPreviewLabel" FontWeight="SemiBold" />
                <Border
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    MinHeight="220"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    HorizontalAlignment="Stretch">
                    <StackPanel Spacing="12">
                        <TextBlock x:Name="PreviewWarningTextBlock" x:Uid="PreviewWarningTextBlock" TextWrapping="WrapWholeWords" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Border
                            x:Name="PreviewHostBorder"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12"
                            MinHeight="180"
                            MaxHeight="480"
                            HorizontalAlignment="Stretch"
                            Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}">
                            <Grid
                                x:Name="PreviewHost"
                                MinHeight="160"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <TextBlock
                x:Name="StatusTextBlock"
                Grid.Row="6"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                TextWrapping="WrapWholeWords"
                IsTextSelectionEnabled="True" />
        </Grid>
    </ScrollViewer>
</Page>
