<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WgcColorCalibrator.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="16" Padding="32">
        <TextBlock x:Uid="SettingsTitle" Style="{ThemeResource TitleTextBlockStyle}" />
        <StackPanel Spacing="8" MaxWidth="420" HorizontalAlignment="Left">
            <TextBlock x:Uid="SettingsLanguageLabel" FontWeight="SemiBold" />
            <ComboBox x:Name="LanguageComboBox" MinWidth="240" SelectedIndex="0">
                <ComboBoxItem x:Uid="LanguageSystem" Tag="system" />
                <ComboBoxItem x:Uid="LanguageZhCn" Tag="zh-CN" />
                <ComboBoxItem x:Uid="LanguageEnUs" Tag="en-US" />
            </ComboBox>
            <Button x:Uid="SettingsApplyLanguage" Click="ApplyLanguage_Click" />
            <TextBlock x:Name="LanguageStatusTextBlock" Text="system" />
        </StackPanel>
    </StackPanel>
</Page>

