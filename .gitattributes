# Auto-detect text files and normalize line endings
* text=auto

# Source code
*.cs text eol=crlf
*.xaml text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
*.json text eol=crlf
*.md text eol=crlf
*.yml text eol=crlf
*.yaml text eol=crlf
*.xml text eol=crlf
*.config text eol=crlf
*.resx text eol=crlf
*.resw text eol=crlf
*.csv text eol=crlf

# Platform scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# Binary files
*.dll binary
*.exe binary
*.pdb binary
*.ico binary
*.png binary
*.cache binary
